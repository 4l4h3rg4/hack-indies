# ===== OPENROUTER (unified API — recomendado) =====
# Una sola API key para todos los modelos (Gemini, OpenAI embeddings, etc.)
# Consíguela en: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ===== LEGACY: Claves individuales (solo si no usas OpenRouter) =====
# GOOGLE_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# ===== SUPABASE CLOUD =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ACCESS_TOKEN=sbp_xxxxxx # PAT from https://supabase.com/dashboard/account/tokens
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ===== APPLICATION =====
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== LLM =====
# Modelo a usar vía OpenRouter. Prefijo "openrouter/" se añade automáticamente.
# Opciones: google/gemini-2.5-flash (gratis), google/gemini-2.5-pro, anthropic/claude-3.5-sonnet
LLM_MODEL=google/gemini-2.5-flash
LLM_TEMPERATURE=0.2

# ===== RAG =====
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ===== ENCRYPTION =====
# Generar con: python -c "from nacl.utils import random; print(random(32).hex())"
ENCRYPTION_KEY=

# ===== WATCHER =====
WATCHER_INTERVAL_MINUTES=60
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
